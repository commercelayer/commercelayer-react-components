{
  "name": "@commercelayer/hooks",
  "version": "1.0.0",
  "description": "Commerce Layer React Hooks",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.cjs"
    }
  },
  "keywords": [
    "jamstack",
    "headless",
    "ecommerce",
    "api",
    "components"
  ],
  "scripts": {
    "check-exports": "attw --pack .",
    "lint": "biome lint --error-on-warnings ./src && tsc",
    "lint:fix": "pnpm biome lint --write ./src",
    "test": "pnpm run lint && vitest run --silent",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "build": "tsdown && pnpm check-compiler",
    "build:watch": "tsdown --watch",
    "ci": "pnpm  build && pnpm check-exports && pnpm lint",
    "check-compiler": "node -e \"for (const f of ['dist/index.js','dist/index.cjs']) if (!require('fs').readFileSync(f,'utf8').includes('react/compiler-runtime')) { console.error('React Compiler output missing in ' + f); process.exit(1) }\""
  },
  "publishConfig": {
    "access": "public"
  },
  "author": {
    "name": "Alessandro Casazza",
    "email": "alessandro@commercelayer.io"
  },
  "license": "MIT",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@babel/core": "^7.29.0",
    "@commercelayer/sdk": "^7.11.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsdown": "^0.22.4",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@commercelayer/core": "workspace:*",
    "swr": "^2.4.1"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  }
}
